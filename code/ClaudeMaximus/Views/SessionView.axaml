<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClaudeMaximus.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="ClaudeMaximus.Views.SessionView"
             x:DataType="vm:SessionViewModel">

    <DockPanel>

        <!-- Session name header -->
        <Border DockPanel.Dock="Top"
                Padding="12,8"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,0,1">
            <TextBlock Text="{Binding Name}"
                       FontSize="16"
                       FontWeight="SemiBold"/>
        </Border>

        <!-- Input area -->
        <Border DockPanel.Dock="Bottom"
                Padding="8"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,1,0,0">
            <Grid RowDefinitions="*,Auto">
                <TextBox Grid.Row="0"
                         x:Name="InputBox"
                         Text="{Binding InputText}"
                         AcceptsReturn="True"
                         MinHeight="80"
                         MaxHeight="200"
                         Watermark="Type a message… (Ctrl+Enter to send)"
                         TextWrapping="Wrap"
                         FontFamily="Cascadia Code,Consolas,monospace"/>
                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="8"
                            Margin="0,4,0,0">
                    <TextBlock Text="Claude is thinking…"
                               VerticalAlignment="Center"
                               Opacity="0.6"
                               IsVisible="{Binding IsBusy}"/>
                    <Button Content="Send"
                            Command="{Binding SendCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Message list -->
        <ScrollViewer x:Name="MessageScroller"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="MessageList"
                          ItemsSource="{Binding Messages}"
                          Margin="0,4,0,4">
                <ItemsControl.DataTemplates>

                    <!-- Single template; each role's panel is shown/hidden via IsVisible.
                         Avalonia uses the first matching DataTemplate per type, so all
                         variants must live inside one template. -->
                    <DataTemplate x:DataType="vm:MessageEntryViewModel">
                        <Panel>

                            <!-- User message -->
                            <Border IsVisible="{Binding IsUser}"
                                    Margin="60,4,8,4"
                                    Padding="10,7"
                                    CornerRadius="8"
                                    Background="#1E3A5F">
                                <StackPanel>
                                    <TextBlock Text="You"
                                               FontSize="11"
                                               Foreground="White"
                                               Opacity="0.6"
                                               Margin="0,0,0,3"/>
                                    <SelectableTextBlock Text="{Binding Content}"
                                                         TextWrapping="Wrap"
                                                         Foreground="White"
                                                         FontFamily="Cascadia Code,Consolas,monospace"
                                                         FontSize="13"/>
                                </StackPanel>
                            </Border>

                            <!-- Assistant message -->
                            <Border IsVisible="{Binding IsAssistant}"
                                    Margin="8,4,60,4"
                                    Padding="10,7"
                                    CornerRadius="8"
                                    Background="#2D4A2D">
                                <StackPanel>
                                    <TextBlock Text="Claude"
                                               FontSize="11"
                                               Foreground="White"
                                               Opacity="0.6"
                                               Margin="0,0,0,3"/>
                                    <SelectableTextBlock Text="{Binding Content}"
                                                         TextWrapping="Wrap"
                                                         Foreground="White"
                                                         FontFamily="Cascadia Code,Consolas,monospace"
                                                         FontSize="13"/>
                                </StackPanel>
                            </Border>

                            <!-- System message -->
                            <Border IsVisible="{Binding IsSystem}"
                                    Margin="20,4,20,4"
                                    Padding="8,5"
                                    CornerRadius="4"
                                    Background="#2A2A2A">
                                <SelectableTextBlock Text="{Binding Content}"
                                                     TextWrapping="Wrap"
                                                     FontSize="12"
                                                     Opacity="0.7"
                                                     FontStyle="Italic"/>
                            </Border>

                            <!-- Compaction separator -->
                            <StackPanel IsVisible="{Binding IsCompaction}"
                                        Margin="8,8,8,8"
                                        Orientation="Vertical"
                                        Spacing="2">
                                <Separator/>
                                <TextBlock Text="― Context compacted above ―"
                                           HorizontalAlignment="Center"
                                           FontSize="11"
                                           Opacity="0.5"
                                           FontStyle="Italic"/>
                                <Separator/>
                            </StackPanel>

                        </Panel>
                    </DataTemplate>

                </ItemsControl.DataTemplates>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>

</UserControl>
