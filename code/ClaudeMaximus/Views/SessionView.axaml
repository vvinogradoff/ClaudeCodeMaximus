<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClaudeMaximus.ViewModels"
             xmlns:views="using:ClaudeMaximus.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="ClaudeMaximus.Views.SessionView"
             x:Name="Root"
             x:DataType="vm:SessionViewModel">

    <Grid RowDefinitions="Auto,*,Auto,5,150">

        <Border Grid.Row="0" Padding="12,6"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <ToggleButton DockPanel.Dock="Right"
                              IsChecked="{Binding IsMarkdownMode}"
                              Content="MD"
                              ToolTip.Tip="Toggle markdown rendering"
                              Padding="8,3" FontSize="11"
                              VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Name}"
                           FontSize="16" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="1" x:Name="MessageScroller"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="MessageList"
                          ItemsSource="{Binding Messages}"
                          Margin="0,4,0,4">
                <ItemsControl.DataTemplates>
                    <DataTemplate x:DataType="vm:MessageEntryViewModel"
                                  x:CompileBindings="False">
                        <Panel>

                            <!-- User message: timestamp left, bubble right -->
                            <Grid IsVisible="{Binding IsUser}" Margin="0,4,8,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="52"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding FormattedTime}"
                                           FontSize="10" Opacity="0.35"
                                           VerticalAlignment="Bottom"
                                           HorizontalAlignment="Right"
                                           Margin="0,0,6,5"/>
                                <Border Grid.Column="1" Padding="10,7" CornerRadius="8" Background="#1E3A5F">
                                    <StackPanel>
                                        <TextBlock Text="You" FontSize="11" Foreground="White" Opacity="0.6" Margin="0,0,0,3"/>
                                        <SelectableTextBlock Text="{Binding Content}"
                                                             TextWrapping="Wrap"
                                                             Foreground="White"
                                                             FontFamily="Cascadia Code,Consolas,monospace"
                                                             FontSize="{Binding DataContext.UserFontSize, ElementName=Root}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Assistant message: text left, timestamp right -->
                            <Grid IsVisible="{Binding IsAssistant}" Margin="8,6,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="52"/>
                                </Grid.ColumnDefinitions>
                                <Panel Grid.Column="0" Margin="0,0,8,0">
                                    <views:MarkdownView
                                        IsVisible="{Binding DataContext.IsMarkdownMode, ElementName=Root}"
                                        Markdown="{Binding Content}"
                                        FontSize="{Binding DataContext.AssistantMarkdownFontSize, ElementName=Root}"/>
                                    <SelectableTextBlock
                                        IsVisible="{Binding !DataContext.IsMarkdownMode, ElementName=Root}"
                                        Text="{Binding Content}"
                                        TextWrapping="Wrap"
                                        FontFamily="Cascadia Code,Consolas,monospace"
                                        FontSize="{Binding DataContext.AssistantFontSize, ElementName=Root}"/>
                                </Panel>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding FormattedTime}"
                                           FontSize="10" Opacity="0.35"
                                           VerticalAlignment="Bottom"
                                           HorizontalAlignment="Left"
                                           Margin="4,0,8,2"/>
                            </Grid>

                            <!-- System message -->
                            <Border IsVisible="{Binding IsSystem}" Margin="20,4,20,4" Padding="8,5" CornerRadius="4" Background="#505050">
                                <SelectableTextBlock Text="{Binding Content}" TextWrapping="Wrap" FontSize="12" Opacity="0.7" FontStyle="Italic"/>
                            </Border>

                            <!-- Compaction separator -->
                            <StackPanel IsVisible="{Binding IsCompaction}" Margin="8,8,8,8" Orientation="Vertical" Spacing="2">
                                <Separator/>
                                <TextBlock Text="&#x2015; Context compacted above &#x2015;"
                                           HorizontalAlignment="Center" FontSize="11" Opacity="0.5" FontStyle="Italic"/>
                                <Separator/>
                            </StackPanel>

                        </Panel>
                    </DataTemplate>
                </ItemsControl.DataTemplates>
            </ItemsControl>
        </ScrollViewer>

        <!-- Row 2: Thinking indicator -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    IsVisible="{Binding IsBusy}"
                    Margin="8,3,8,3"
                    Spacing="6">
            <TextBlock Text="Claude is thinking…"
                       FontStyle="Italic"
                       Opacity="0.5"
                       FontSize="13"/>
            <TextBlock Text="{Binding ThinkingDuration}"
                       FontStyle="Italic"
                       Opacity="0.5"
                       FontSize="13"
                       Foreground="#888888"/>
        </StackPanel>

        <GridSplitter Grid.Row="3" ResizeDirection="Rows"
                      Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"/>

        <Border Grid.Row="4" Padding="8"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0" x:Name="InputBox"
                         Text="{Binding InputText}"
                         AcceptsReturn="True"
                         Watermark="Type a message... (Ctrl+Enter to send)"
                         TextWrapping="Wrap"
                         FontFamily="Cascadia Code,Consolas,monospace"
                         FontSize="{Binding InputFontSize}"/>
                <Button Grid.Column="1"
                        Content="Send"
                        VerticalAlignment="Stretch"
                        VerticalContentAlignment="Center"
                        Margin="8,0,0,0"
                        Command="{Binding SendCommand}"/>
            </Grid>
        </Border>

    </Grid>

</UserControl>