<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClaudeMaximus.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="ClaudeMaximus.Views.SessionView"
             x:DataType="vm:SessionViewModel">

    <Grid RowDefinitions="Auto,*,5,150">

        <!-- Row 0: Session name header -->
        <Border Grid.Row="0"
                Padding="12,8"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,0,1">
            <TextBlock Text="{Binding Name}"
                       FontSize="16"
                       FontWeight="SemiBold"/>
        </Border>

        <!-- Row 1: Message list -->
        <ScrollViewer Grid.Row="1"
                      x:Name="MessageScroller"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
            <ItemsControl x:Name="MessageList"
                          ItemsSource="{Binding Messages}"
                          Margin="0,4,0,4">
                <ItemsControl.DataTemplates>

                    <!-- Single template; each role's panel is shown/hidden via IsVisible.
                         Avalonia uses the first matching DataTemplate per type, so all
                         variants must live inside one template. -->
                    <DataTemplate x:DataType="vm:MessageEntryViewModel">
                        <Panel>

                            <!-- User message -->
                            <Border IsVisible="{Binding IsUser}"
                                    Margin="60,4,8,4"
                                    Padding="10,7"
                                    CornerRadius="8"
                                    Background="#1E3A5F">
                                <StackPanel>
                                    <TextBlock Text="You"
                                               FontSize="11"
                                               Foreground="White"
                                               Opacity="0.6"
                                               Margin="0,0,0,3"/>
                                    <SelectableTextBlock Text="{Binding Content}"
                                                         TextWrapping="Wrap"
                                                         Foreground="White"
                                                         FontFamily="Cascadia Code,Consolas,monospace"
                                                         FontSize="13"/>
                                </StackPanel>
                            </Border>

                            <!-- Assistant message -->
                            <SelectableTextBlock IsVisible="{Binding IsAssistant}"
                                                 Text="{Binding Content}"
                                                 Margin="8,6,60,6"
                                                 TextWrapping="Wrap"
                                                 FontFamily="Cascadia Code,Consolas,monospace"
                                                 FontSize="13"/>

                            <!-- System message -->
                            <Border IsVisible="{Binding IsSystem}"
                                    Margin="20,4,20,4"
                                    Padding="8,5"
                                    CornerRadius="4"
                                    Background="#2A2A2A">
                                <SelectableTextBlock Text="{Binding Content}"
                                                     TextWrapping="Wrap"
                                                     FontSize="12"
                                                     Opacity="0.7"
                                                     FontStyle="Italic"/>
                            </Border>

                            <!-- Compaction separator -->
                            <StackPanel IsVisible="{Binding IsCompaction}"
                                        Margin="8,8,8,8"
                                        Orientation="Vertical"
                                        Spacing="2">
                                <Separator/>
                                <TextBlock Text="― Context compacted above ―"
                                           HorizontalAlignment="Center"
                                           FontSize="11"
                                           Opacity="0.5"
                                           FontStyle="Italic"/>
                                <Separator/>
                            </StackPanel>

                        </Panel>
                    </DataTemplate>

                </ItemsControl.DataTemplates>
            </ItemsControl>

            <!-- "Claude is thinking" indicator — sits below the last message bubble -->
            <TextBlock Text="Claude is thinking…"
                       IsVisible="{Binding IsBusy}"
                       Margin="8,4,60,8"
                       Foreground="White"
                       Opacity="0.5"
                       FontStyle="Italic"
                       FontSize="13"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Row 2: Vertical splitter -->
        <GridSplitter Grid.Row="2"
                      ResizeDirection="Rows"
                      Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"/>

        <!-- Row 3: Input area -->
        <Border Grid.Row="3"
                Padding="8"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0"
                         x:Name="InputBox"
                         Text="{Binding InputText}"
                         AcceptsReturn="True"
                         Watermark="Type a message… (Ctrl+Enter to send)"
                         TextWrapping="Wrap"
                         FontFamily="Cascadia Code,Consolas,monospace"/>
                <Button Grid.Column="1"
                        Content="Send"
                        VerticalAlignment="Stretch"
                        Margin="8,0,0,0"
                        Command="{Binding SendCommand}"/>
            </Grid>
        </Border>

    </Grid>

</UserControl>
