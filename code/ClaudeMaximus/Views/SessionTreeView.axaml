<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClaudeMaximus.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="ClaudeMaximus.Views.SessionTreeView"
             x:DataType="vm:SessionTreeViewModel">

    <DockPanel>

        <!-- Search box -->
        <Border DockPanel.Dock="Top" Padding="4,4,4,2">
            <TextBox Text="{Binding SearchText}"
                     Watermark="Search sessions…"/>
        </Border>

        <!-- Add Directory button -->
        <Button DockPanel.Dock="Bottom"
                Content="+ Add Directory"
                HorizontalAlignment="Stretch"
                Margin="4"
                Click="OnAddDirectoryClicked"/>

        <!-- Tree -->
        <TreeView x:Name="Tree"
                  ItemsSource="{Binding Directories}"
                  SelectionChanged="OnTreeSelectionChanged">
            <TreeView.DataTemplates>

                <!-- Directory node — reflection bindings used because compiled bindings
                     do not correctly resolve x:DataType inside TreeView.DataTemplates -->
                <TreeDataTemplate DataType="vm:DirectoryNodeViewModel"
                                  x:CompileBindings="False"
                                  ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="2,1">
                        <TextBlock Text="&#128193;" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Label}" VerticalAlignment="Center"/>
                        <StackPanel.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Add Group"   Tag="AddGroupToDirectory"   Click="OnContextMenuClicked"/>
                                <MenuItem Header="Add Session" Tag="AddSessionToDirectory" Click="OnContextMenuClicked"/>
                                <Separator/>
                                <MenuItem Header="Delete"      Tag="DeleteDirectory"        Click="OnContextMenuClicked"/>
                            </ContextMenu>
                        </StackPanel.ContextMenu>
                    </StackPanel>
                </TreeDataTemplate>

                <!-- Group node -->
                <TreeDataTemplate DataType="vm:GroupNodeViewModel"
                                  x:CompileBindings="False"
                                  ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="2,1">
                        <TextBlock Text="&#128194;" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                        <StackPanel.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Add Group"   Tag="AddGroupToGroup"   Click="OnContextMenuClicked"/>
                                <MenuItem Header="Add Session" Tag="AddSessionToGroup" Click="OnContextMenuClicked"/>
                                <Separator/>
                                <MenuItem Header="Rename"      Tag="RenameGroup"       Click="OnContextMenuClicked"/>
                                <MenuItem Header="Delete"      Tag="DeleteGroup"        Click="OnContextMenuClicked"/>
                            </ContextMenu>
                        </StackPanel.ContextMenu>
                    </StackPanel>
                </TreeDataTemplate>

                <!-- Session node -->
                <DataTemplate DataType="vm:SessionNodeViewModel"
                              x:CompileBindings="False">
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="2,1">
                        <Ellipse Width="8" Height="8"
                                 Fill="LimeGreen"
                                 VerticalAlignment="Center"
                                 IsVisible="{Binding IsRunning}"/>
                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                        <StackPanel.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Rename" Tag="RenameSession" Click="OnContextMenuClicked"/>
                                <Separator/>
                                <MenuItem Header="Delete" Tag="DeleteSession"  Click="OnContextMenuClicked"/>
                            </ContextMenu>
                        </StackPanel.ContextMenu>
                    </StackPanel>
                </DataTemplate>

            </TreeView.DataTemplates>
        </TreeView>

    </DockPanel>

</UserControl>
